// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// --- Enums ---
enum Role {
  USER       // Thomas, Sophie (Group Hosts)
  BAR_OWNER  // Venue/Bar owner
}

enum Gender {
  MALE
  FEMALE
  MIXED
  OTHER      // Entspricht "Other" im UI
  ANY        // Entspricht "Any" im UI
}

enum GroupType {
  FRIENDS
  DATES
  NETWORKING
}

model User {
  id              String      @id @default(cuid())
  name            String
  username        String?     @unique
  email           String      @unique
  password        String
  birthDate       DateTime
  role            Role        @default(USER)
  isGuest         Boolean     @default(false)
  image           String?     
  
  group           Group?      @relation("HostGroup")
  events          Event[]
  chatsInitiated  Chat[]      @relation("HostA")
  chatsReceived   Chat[]      @relation("HostB")
  messages        Message[]
  gameScores      GameScore[]

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

model Group {
  id             String    @id @default(cuid())
  userId         String    @unique
  user           User      @relation("HostGroup", fields: [userId], references: [id], onDelete: Cascade)

  // Group Details
  membersCount   Int       @default(1)
  gender         String    @default("ANY")
  ageMin         Int       @default(18)
  ageMax         Int       @default(30)

  // Photos
  photos         String[]  // max 6

  // Search Preferences
  searchGender   String    @default("ANY")
  searchAgeMax   Int       @default(35)
  maxDistance    Int       @default(10)

  // Public Profile
  publicProfile  Boolean   @default(true)

  // Description
  description    String?   @db.VarChar(200)

  // Instagram
  instagram      String[]

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}


model Event {
  id            String    @id @default(cuid())
  title         String    
  description   String?
  locationName  String    
  latitude      Float
  longitude     Float
  startTime     DateTime
  endTime       DateTime?
  
  ownerId       String
  owner         User      @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  createdAt     DateTime  @default(now())
}

model Chat {
  id        String    @id @default(cuid())
  hostAId   String
  hostA     User      @relation("HostA", fields: [hostAId], references: [id], onDelete: Cascade)
  hostBId   String
  hostB     User      @relation("HostB", fields: [hostBId], references: [id], onDelete: Cascade)
  messages  Message[]
  createdAt DateTime  @default(now())

  @@unique([hostAId, hostBId])
}

model Message {
  id        String   @id @default(cuid())
  text      String
  chatId    String
  chat      Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)
  senderId  String
  sender    User     @relation(fields: [senderId], references: [id])
  createdAt DateTime @default(now())
}

model GameScore {
  id        String   @id @default(cuid())
  gameName  String   
  score     Int      
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  guestId   String?  
  createdAt DateTime @default(now())

  @@index([gameName, score(sort: Desc)])
}
// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ROLES: Barbesitzer haben andere Berechtigungen als reguläre Nutzer
enum Role {
  USER       // Thomas, Sophie (Gruppen-Hosts)
  BAR_OWNER  // Venue/Bar-Besitzer
}

model User {
  id              String      @id @default(cuid())
  // Daten aus dem Register-Formular (page_4)
  firstName       String?
  lastName        String?
  email           String      @unique
  password        String      // Für den Login-Flow benötigt
  dateOfBirth     DateTime?   // 'dob' aus dem Formular
  phone           String?     // 'phone' aus dem Formular
  
  username        String?     // Optionaler Anzeigename
  role            Role        @default(USER)
  isGuest         Boolean     @default(false) // Steuert den Teaser-Modus im Dashboard
  image           String?     // Profilbild (scharf oder verpixelt je nach Gast-Status)
  
  // RELATIONEN
  // Ein Host (User) erstellt EINE Gruppe zum Ausgehen
  group           Group?      @relation("HostGroup")
  
  // Ein Bar-Besitzer kann mehrere Events/Partys erstellen
  events          Event[]

  // CHATS: Austausch zwischen Gruppen-Hosts
  chatsInitiated  Chat[]      @relation("HostA")
  chatsReceived   Chat[]      @relation("HostB")
  messages        Message[]

  gameScores      GameScore[]
  
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

model Group {
  id            String    @id @default(cuid())
  hostName      String    
  description   String?   // z.B. "Vorglühen bei Thomas"
  instaLink     String?   
  
  // Mitglieder, die nicht in der App registriert sind (Anzahl der Freunde)
  membersCount  Int       @default(1) 
  
  isPartyMode   Boolean   @default(true) 
  latitude      Float?    
  longitude     Float?    
  
  // Relation zum Host (User)
  hostId        String    @unique
  host          User      @relation("HostGroup", fields: [hostId], references: [id])

  createdAt     DateTime  @default(now())
}

model Event {
  id            String    @id @default(cuid())
  title         String    // z.B. "Techno Night"
  description   String?
  locationName  String    // Name der Bar
  latitude      Float
  longitude     Float
  startTime     DateTime
  endTime       DateTime?
  
  // Relation zum Bar-Besitzer (User)
  ownerId       String
  owner         User      @relation(fields: [ownerId], references: [id])

  createdAt     DateTime  @default(now())
}

model Chat {
  id          String    @id @default(cuid())
  
  // Verbindet zwei Hosts (User)
  hostAId     String
  hostA       User      @relation("HostA", fields: [hostAId], references: [id])
  
  hostBId     String
  hostB       User      @relation("HostB", fields: [hostBId], references: [id])
  
  messages    Message[]
  createdAt   DateTime  @default(now())

  @@unique([hostAId, hostBId])
}

model Message {
  id          String   @id @default(cuid())
  text        String
  chatId      String
  chat        Chat     @relation(fields: [chatId], references: [id])
  
  senderId    String
  sender      User     @relation(fields: [senderId], references: [id])
  
  createdAt   DateTime @default(now())
}

model GameScore {
  id          String   @id @default(cuid())
  gameName    String   // "BeerPong", "Quiz"
  score       Int      
  
  // Registrierter User (ID wird gespeichert)
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])
  
  // Gast-User (ID wird über Cookie/localStorage getrackt)
  guestId     String?  

  createdAt   DateTime @default(now())

  @@index([gameName, score(sort: Desc)])
}
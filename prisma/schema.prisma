// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- Enums ---
enum Role {
  USER       // Thomas, Sophie (Group Hosts)
  BAR_OWNER  // Venue/Bar owner
}

enum Gender {
  MALE
  FEMALE
  MIXED
  OTHER      // Entspricht "Other" im UI
  ANY        // Entspricht "Any" im UI
}

enum GroupType {
  FRIENDS
  DATES
  NETWORKING
}

model User {
  id              String      @id @default(cuid())
  name            String
  username        String?     @unique
  email           String      @unique
  password        String
  birthDate       DateTime
  role            Role        @default(USER)
  isGuest         Boolean     @default(false)
  image           String?     
  
  group           Group?      @relation("HostGroup")
  events          Event[]
  chatsInitiated  Chat[]      @relation("HostA")
  chatsReceived   Chat[]      @relation("HostB")
  messages        Message[]
  gameScores      GameScore[]

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

model Group {
  id               String      @id @default(cuid())
  userId           String      @unique
  user             User        @relation("HostGroup",fields: [userId], references: [id], onDelete: Cascade)
  
  // Group Info
  description      String?
  membersCount     Int         @default(1)
  gender           Gender      @default(ANY)
  ageMin           Int         @default(18)
  ageMax           Int         @default(30)
  
  // Search Preferences
  searchGender     Gender      @default(ANY)
  searchAgeMax     Int         @default(35)
  maxDistance      Int         @default(10)
  isPartyMode      Boolean     @default(false)
  publicProfile    Boolean     @default(true)
  
  // Media & Social
  photos           String[]    // Array of URLs
  instagram        String[]
  
  // Location (Needed for "Nearby" logic)
  latitude         Float?
  longitude        Float?

  // Relations
  likesSent        GroupLike[] @relation("LikesSent")
  likesReceived    GroupLike[] @relation("LikesReceived")

  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
}

model GroupLike {
  id            String   @id @default(cuid())
  fromGroupId   String
  fromGroup     Group    @relation("LikesSent", fields: [fromGroupId], references: [id], onDelete: Cascade)
  toGroupId     String
  toGroup       Group    @relation("LikesReceived", fields: [toGroupId], references: [id], onDelete: Cascade)
  
  createdAt     DateTime @default(now())

  @@unique([fromGroupId, toGroupId]) // One like per pair of groups
}


model Event {
  id            String    @id @default(cuid())
  title         String    
  description   String?
  locationName  String    
  latitude      Float
  longitude     Float
  startTime     DateTime
  endTime       DateTime?
  
  ownerId       String
  owner         User      @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  createdAt     DateTime  @default(now())
}

model Chat {
  id        String    @id @default(cuid())
  hostAId   String
  hostA     User      @relation("HostA", fields: [hostAId], references: [id], onDelete: Cascade)
  hostBId   String
  hostB     User      @relation("HostB", fields: [hostBId], references: [id], onDelete: Cascade)
  messages  Message[]
  createdAt DateTime  @default(now())

  @@unique([hostAId, hostBId])
}

model Message {
  id        String   @id @default(cuid())
  text      String
  chatId    String
  chat      Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)
  senderId  String
  sender    User     @relation(fields: [senderId], references: [id])
  createdAt DateTime @default(now())
}

model GameScore {
  id        String   @id @default(cuid())
  gameName  String   
  score     Int      
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  guestId   String?  
  createdAt DateTime @default(now())

  @@index([gameName, score(sort: Desc)])
}
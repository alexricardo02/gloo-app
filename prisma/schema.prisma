generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id                  String        @id @default(cuid())
  name                String
  username            String?       @unique
  email               String        @unique
  password            String
  birthDate           DateTime
  role                Role          @default(USER)
  isGuest             Boolean       @default(false)
  image               String?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  isVerified          Boolean       @default(false)
  verificationToken   String?       @unique
  resetPasswordExpiry DateTime?
  resetPasswordToken  String?       @unique
  chatsInitiated      Chat[]        @relation("HostA")
  chatsReceived       Chat[]        @relation("HostB")
  events              Event[]
  gameScores          GameScore[]
  group               Group?        @relation("HostGroup")
  blockedGroups       GroupBlock[]
  filedReports        GroupReport[]
  messages            Message[]
}

model Group {
  id               String            @id @default(cuid())
  description      String?
  membersCount     Int               @default(1)
  ageMin           Int               @default(18)
  ageMax           Int               @default(30)
  searchAgeMax     Int               @default(35)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  instagram        String[]
  maxDistance      Int               @default(10)
  photos           String[]
  userId           String            @unique
  isPartyMode      Boolean           @default(false)
  latitude         Float?
  longitude        Float?
  gender           Gender            @default(MIXED)
  searchGender     Gender            @default(MIXED)
  publicProfile    Boolean           @default(true)
  searchAgeMin     Int               @default(18)
  eventAttendances EventAttendance[]
  user             User              @relation("HostGroup", fields: [userId], references: [id], onDelete: Cascade)
  blocksReceived   GroupBlock[]
  likesSent        GroupLike[]       @relation("LikesSent")
  likesReceived    GroupLike[]       @relation("LikesReceived")
  reportsReceived  GroupReport[]
  venueAttendances VenueAttendance[]
}

model GroupLike {
  id          String   @id @default(cuid())
  fromGroupId String
  toGroupId   String
  createdAt   DateTime @default(now())
  fromGroup   Group    @relation("LikesSent", fields: [fromGroupId], references: [id], onDelete: Cascade)
  toGroup     Group    @relation("LikesReceived", fields: [toGroupId], references: [id], onDelete: Cascade)

  @@unique([fromGroupId, toGroupId])
}

model Event {
  id           String            @id @default(cuid())
  title        String
  description  String?
  locationName String
  latitude     Float
  longitude    Float
  startTime    DateTime
  endTime      DateTime?
  ownerId      String
  createdAt    DateTime          @default(now())
  owner        User              @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  attendees    EventAttendance[]
}

model Chat {
  id        String    @id @default(cuid())
  hostAId   String
  hostBId   String
  createdAt DateTime  @default(now())
  hostA     User      @relation("HostA", fields: [hostAId], references: [id], onDelete: Cascade)
  hostB     User      @relation("HostB", fields: [hostBId], references: [id], onDelete: Cascade)
  messages  Message[]

  @@unique([hostAId, hostBId])
}

model Message {
  id        String   @id @default(cuid())
  text      String
  chatId    String
  senderId  String
  createdAt DateTime @default(now())
  chat      Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)
  sender    User     @relation(fields: [senderId], references: [id], onDelete: Cascade)
}

model GameScore {
  id        String   @id @default(cuid())
  gameName  String
  score     Int
  userId    String?
  guestId   String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])

  @@index([gameName, score(sort: Desc)])
}

model EventAttendance {
  id        String   @id @default(cuid())
  groupId   String
  eventId   String
  createdAt DateTime @default(now())
  status    String   @default("Pending")
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  group     Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([groupId, eventId])
}

model Venue {
  id        String            @id @default(cuid())
  name      String
  type      String
  latitude  Float
  longitude Float
  createdAt DateTime          @default(now())
  attendees VenueAttendance[]
}

model VenueAttendance {
  id        String   @id @default(cuid())
  groupId   String
  venueId   String
  createdAt DateTime @default(now())
  group     Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  venue     Venue    @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@unique([groupId, venueId])
}

model GroupBlock {
  id             String   @id @default(cuid())
  blockerId      String
  blockedGroupId String
  createdAt      DateTime @default(now())
  blockedGroup   Group    @relation(fields: [blockedGroupId], references: [id], onDelete: Cascade)
  blocker        User     @relation(fields: [blockerId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedGroupId])
}

model GroupReport {
  id              String   @id @default(cuid())
  reporterId      String
  reportedGroupId String
  reason          String?
  createdAt       DateTime @default(now())
  reportedGroup   Group    @relation(fields: [reportedGroupId], references: [id], onDelete: Cascade)
  reporter        User     @relation(fields: [reporterId], references: [id], onDelete: Cascade)

  @@unique([reporterId, reportedGroupId])
}

enum Role {
  USER
  BAR_OWNER
}

enum Gender {
  MALE
  FEMALE
  MIXED
  DIVERSE
}

enum GroupType {
  FRIENDS
  DATES
  NETWORKING
}

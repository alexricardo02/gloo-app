// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Roles: Bar owners have different permissions than regular users
enum Role {
  USER       // Thomas, Sophie (Group Hosts)
  BAR_OWNER  // Venue/Bar owner
}

model User {
  id            String    @id @default(cuid())
  name          String
  username      String?   @unique// Changed from 'name' to 'username'
  email         String    @unique
  password      String
  birthDate     DateTime
  role          Role      @default(USER) // Bar Owner vs Regular User
  isGuest       Boolean   @default(false)
  image         String?   
  
  group          Group?      @relation("HostGroup")
  events         Event[]
  chatsInitiated Chat[]      @relation("HostA")
  chatsReceived  Chat[]      @relation("HostB")
  messages       Message[]
  gameScores     GameScore[]

  createdAt      DateTime    @default(now())
}

model Group {
  id            String   @id @default(cuid())
  hostName      String   
  description   String?  
  instaLink     String?  
  
  // --- Group Info (image_649842.jpg) ---
  membersCount  Int      @default(1)  // "Number of people"
  ageMin        Int      @default(18) // Slider Start
  ageMax        Int      @default(30) // Slider Ende
  groupGender   String   @default("Mixed") // "Group Gender": Men, Women, Mixed
  
  // Bilder-URLs (für die Upload-Sektion im UI)
  images        String[] 

  // --- Search Preferences ---
  searchAgeMin  Int      @default(18) // "Age of groups to search for"
  searchAgeMax  Int      @default(35)
  seekingGender String   @default("Any")   // "Genders we seek": Only Men, Only Women, Any
  groupType     String   @default("Friends") // "Group types": Friends, Dates, Networking

  // --- Location & System ---
  isPartyMode   Boolean  @default(true) 
  latitude      Float?   
  longitude     Float?   
  
  hostId        String   @unique
  host          User     @relation("HostGroup", fields: [hostId], references: [id])

  createdAt     DateTime @default(now())
}

model Event {
  id            String    @id @default(cuid())
  title         String    
  description   String?
  locationName  String    
  latitude      Float
  longitude     Float
  startTime     DateTime
  endTime       DateTime?
  
  ownerId       String
  owner         User      @relation(fields: [ownerId], references: [id])

  createdAt     DateTime  @default(now())
}

model Chat {
  id        String    @id @default(cuid())
  hostAId   String
  hostA     User      @relation("HostA", fields: [hostAId], references: [id])
  hostBId   String
  hostB     User      @relation("HostB", fields: [hostBId], references: [id])
  messages  Message[]
  createdAt DateTime  @default(now())

  @@unique([hostAId, hostBId])
}

model Message {
  id        String   @id @default(cuid())
  text      String
  chatId    String
  chat      Chat     @relation(fields: [chatId], references: [id])
  senderId  String
  sender    User     @relation(fields: [senderId], references: [id])
  createdAt DateTime @default(now())
}

model GameScore {
  id        String   @id @default(cuid())
  gameName  String   
  score     Int      
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  guestId   String?  
  createdAt DateTime @default(now())

  @@index([gameName, score(sort: Desc)])
}